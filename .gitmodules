[submodule "vendor/godot_voxel"]
	path = vendor/modules/voxel
	url = https://github.com/dsrw/godot_voxel.git
	branch = master
[submodule "vendor/godot"]
	path = vendor/godot
	url = https://github.com/dsrw/godot.git
	branch = enu
	ignore = untracked
[submodule "vendor/pcre"]
	path = vendor/pcre
	url = https://github.com/luvit/pcre
	ignore = dirty
[submodule "vendor/llama.cpp"]
	path = vendor/llama.cpp
	url = https://github.com/ggml-org/llama.cpp
	ignore = dirty
