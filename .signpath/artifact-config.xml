<?xml version="1.0" encoding="utf-8"?>
<artifact-configuration xmlns="http://signpath.io/artifact-configuration/v1">
  <artifact-set>
    <!-- Sign the installer executable -->
    <pe-file path="enu-*-installer.exe" />

    <!-- Deep sign the zip archive contents -->
    <zip-file path="enu-*-windows-x64.zip">
      <directory path="enu-*">
        <!-- Sign the main executable -->
        <pe-file path="enu.exe" />
        <!-- Sign the Nim library -->
        <pe-file path="enu.dll" />
      </directory>
    </zip-file>
  </artifact-set>
</artifact-configuration>
