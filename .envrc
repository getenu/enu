# Automatically add project binaries to PATH when entering this directory
# Requires direnv: https://direnv.net/
# After creating this file, run: direnv allow

PATH_add vendor/nim/bin
PATH_add nimbledeps/bin

# Windows-specific paths (MinGW and Python from build_env)
if [[ "$OSTYPE" == "msys" || "$OSTYPE" == "cygwin" || "$OSTYPE" =~ ^mingw ]]; then
    PATH_add build_env/mingw64/bin
    PATH_add build_env/python
    PATH_add build_env/python/Scripts
fi
