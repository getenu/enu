# ignore all files with no extension (unix binaries)
*
!/**/
!*.*
!AppRun

vendor/pcre

*.dSYM
*.so
*.dylib
*.dll
*.a
scratch/
tools/build_helpers
tools/build_helpers.exe
logs/
*.exe
*.out
*.log

app/.import
.DS_Store
app/enu.exp
app/enu.lib

generated/
app/export_presets.cfg
docs/build
dist/
vmlib/stdlib
dist_config.json
user_config.nims
/build_env

/.last_test
nimble.develop
nimble.paths
/t.nim
.submodules.tmp

*.previous
.claude/
deps/
nimbledeps/
nim.cfg
.build_arch
app/level.json
app/project.nim
app/project.nimble

# Per-level IDE/agent files Enu generates into worlds (regenerated on load).
# nim.cfg, generated/ and .claude/ are already ignored globally above; the
# per-level .gitignore self-ignores.
vmlib/worlds/**/project.nim
vmlib/worlds/**/project.nimble
vmlib/worlds/**/CLAUDE.md
vmlib/worlds/**/.mcp.json
